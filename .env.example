# ── Client-safe (the ONLY variables allowed to start with VITE_) ─────────────
# Supabase anon key is designed to be public; RLS is the security boundary.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Server-only (Vercel project env vars; NEVER prefixed VITE_, NEVER in src/) ─
# Supabase service role: bypasses RLS; /api code only.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google Places API (New). Server-restricted key (API restriction: Places only).
GOOGLE_PLACES_API_KEY=AIza...

# ElevenLabs
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_CALLER_AGENT_ID=agent_...
ELEVENLABS_RECEPTIONIST_AGENT_ID=agent_...
ELEVENLABS_WEBHOOK_SECRET=whsec_...
ELEVENLABS_CALLER_PHONE_NUMBER_ID=phnum_...   # ElevenLabs phone-number id of the outbound number

# Twilio (numbers are imported into ElevenLabs; these stay for usage reconciliation)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
SANDBOX_RECEPTIONIST_NUMBER=+1416...          # the "clinic" number dialled in dry-run mode

# Anthropic (fork F6 transcript post-processing only)
ANTHROPIC_API_KEY=sk-ant-...

# Product
CONTACT_EMAIL=shohei.kato1@gmail.com          # CRTC contact-info string, valid 60+ days
CRON_SECRET=...                               # protects /api/cron/watchdog
